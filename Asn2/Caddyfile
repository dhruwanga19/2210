# Auto-TLS via Let's Encrypt. The GAME_DOMAIN env var is supplied by
# docker-compose (loaded from .env on the host).

{$GAME_DOMAIN} {
	encode zstd gzip

	# noVNC needs WebSocket upgrade; reverse_proxy handles it automatically.
	reverse_proxy game:6080

	# Redirect bare "/" to the auto-connecting noVNC client so visitors
	# land directly in the game.
	@root path /
	redir @root /vnc.html?autoconnect=1&resize=scale&reconnect=1 302
}
